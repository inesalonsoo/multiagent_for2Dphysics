# Secrets -- never commit
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/

# Data (raw trajectories, gitignored per CLAUDE.md -- streamed/regenerated, not tracked)
data/*
!data/.gitkeep

